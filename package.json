{
  "name": "@repo/content-cli",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "content-cli": "./dist/cli.js"
  },
  "files": [
    "dist/**",
    "src/**"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@repo/content-blocks": "workspace:*",
    "@repo/content-extractors": "workspace:*",
    "@repo/content-manager": "workspace:*",
    "@repo/content-scanner": "workspace:*",
    "@repo/indexer-api": "workspace:*",
    "@repo/indexer-mem-flexsearch": "workspace:*",
    "@statewalker/webrun-files": "catalog:",
    "@statewalker/webrun-files-node": "^0.7.0"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "tsx": "^4.19.4",
    "typescript": "catalog:"
  }
}
