{
  "name": "@repo/content-scanner",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist/**",
    "src/**"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@repo/content-blocks": "workspace:*",
    "@repo/content-extractors": "workspace:*",
    "@repo/indexer-api": "workspace:*",
    "@repo/indexer-chunker": "workspace:*",
    "@repo/streams": "workspace:*",
    "@statewalker/webrun-files": "catalog:"
  },
  "devDependencies": {
    "@statewalker/webrun-files-mem": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
