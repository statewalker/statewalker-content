{
  "name": "@repo/content-extractors",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./extractors": "./src/extractors/index.ts"
  },
  "files": [
    "dist/**",
    "src/**"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@repo/content-blocks": "workspace:*",
    "exceljs": "^4.4.0",
    "mammoth": "^1.8.0",
    "markdown-it": "^14.1.0",
    "unpdf": "^1.4.0",
    "turndown": "^7.2.0",
    "@joplin/turndown-plugin-gfm": "^1.0.56"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/turndown": "^5.0.5",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
