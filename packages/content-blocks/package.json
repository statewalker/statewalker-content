{
  "name": "@statewalker/content-blocks",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Content block types: document/section/paragraph/etc. The unit passed between extractors, scanners, and indexers.",
  "homepage": "https://github.com/statewalker/statewalker-content",
  "author": {
    "name": "Mikhail Kotelnikov",
    "email": "mikhail.kotelnikov@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/statewalker/statewalker-content.git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./ids": "./src/ids/index.ts",
    "./parser": "./src/parser/index.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "lint": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@statewalker/ids": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
